{
  "name": "@HTMLgtMK/redis-channel",
  "version": "1.1.3",
  "description": "OpenClaw Channel plugin for Redis Pub/Sub messaging",
  "main": "dist/plugin.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "dist/plugin.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:pub": "ts-node scripts/test-publish.ts",
    "test:sub": "ts-node scripts/test-subscribe.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "channel",
    "redis",
    "pubsub"
  ],
  "license": "MIT",
  "dependencies": {
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0"
  },
  "bundleDependencies": [
    "ioredis",
    "uuid",
    "typescript",
    "openclaw",
    "@types/node",
    "@types/uuid",
    "ts-node"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "commander": "^11.0.0",
    "openclaw": "^2026.3.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
